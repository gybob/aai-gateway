{
  "name": "aai-gateway",
  "version": "0.9.0",
  "type": "module",
  "main": "dist/index.js",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "aai-gateway": "dist/cli.js"
  },
  "scripts": {
    "dev": "vite-node src/index.ts",
    "build": "tsc && vite build && chmod +x dist/cli.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest --passWithNoTests",
    "test:coverage": "vitest run --coverage --passWithNoTests",
    "test:single": "vitest run --testNamePattern",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "aai",
    "agent",
    "mcp",
    "automation",
    "applescript",
    "com",
    "dbus"
  ],
  "author": "Bob",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gybob/aai-gateway.git"
  },
  "homepage": "https://github.com/gybob/aai-gateway#readme",
  "bugs": {
    "url": "https://github.com/gybob/aai-gateway/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "overrides": {
    "@modelcontextprotocol/sdk": {
      "@hono/node-server": "^1.19.10",
      "hono": "^4.12.7",
      "express-rate-limit": "^8.2.2",
      "ajv": "^8.18.0",
      "qs": "^6.14.2"
    },
    "eslint-plugin-import": {
      "minimatch": "^3.1.4"
    }
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "pino": "^8.17.0",
    "pino-pretty": "^10.3.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "@vitest/coverage-v8": "^4.1.1",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.29.0",
    "prettier": "^3.1.0",
    "typescript": "^5.3.0",
    "vite": "^8.0.2",
    "vite-node": "^6.0.0",
    "vitest": "^4.1.1"
  }
}
